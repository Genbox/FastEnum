// Tests sorting options on EnumTransform (names, values, underlying, display, description)

[FastEnum]
[EnumTransform(SortMemberNames = EnumOrder.Descending, SortMemberValues = EnumOrder.Descending, SortUnderlyingValues = EnumOrder.Descending, SortDisplayNames = EnumOrder.Descending, SortDescriptions = EnumOrder.Descending)]
public enum SortedEnum
{
    [System.ComponentModel.DataAnnotations.Display(Name = "Bravo", Description = "Second")]
    One = 2,

    [System.ComponentModel.DataAnnotations.Display(Name = "Alpha", Description = "First")]
    Two = 1,

    [System.ComponentModel.DataAnnotations.Display(Name = "Charlie", Description = "Third")]
    Three = 3,
}
